{
  "name": "orga-pro",
  "version": "1.0.0",
  "description": "Application de génération et maintenance d'organigrammes professionnels",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "Votre Entreprise",
  "license": "Proprietary",
  "scripts": {
    "start": "cross-env PORT=3001 cross-env BROWSER=none react-scripts start",
    "react-build": "react-scripts build",
    "electron": "electron .",
    "dev": "concurrently \"npm run start\" \"wait-on http://localhost:3001 && npm run electron\"",
    "dev:clean": "cross-env NODE_NO_WARNINGS=1 concurrently \"npm run start\" \"wait-on http://localhost:3001 && npm run electron\"",
    "dev:debug": "cross-env ELECTRON_IS_DEV=1 npm run dev",
    "build": "npm run react-build && electron-builder",
    "build:unpacked": "npm run react-build && electron-builder --dir",
    "test": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "check": "npm run lint && npm run test",
    "generate:example": "node scripts/generateExampleExcel.js",
    "eject": "react-scripts eject",
    "serve": "electron-serve ."
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-serve": "^1.0.1",
    "elkjs": "^0.11.0",
    "html2canvas": "^1.4.1",
    "pdfkit": "^0.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1",
    "sharp": "^0.33.0",
    "svg-to-pdfkit": "^0.1.8",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "eslint": "^8.54.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react": "^7.33.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "wait-on": "^7.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
